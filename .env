# Jackbeat — Variables d'environnement
# Copier ce fichier en ".env" et remplir les valeurs

# Clé secrète Flask (générer une vraie clé en production)
SECRET_KEY=

# Credentials Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Base de données (laisser vide pour SQLite en dev)
DATABASE_URL=

# Environnement
FLASK_ENV=development
